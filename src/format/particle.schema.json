{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ParticleDoc",
  "definitions": {
    "ParticleDoc": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "number",
          "const": 4
        },
        "meta": {
          "$ref": "#/definitions/ParticleMeta"
        },
        "duration": {
          "type": "number"
        },
        "looping": {
          "type": "boolean"
        },
        "seed": {
          "type": "number"
        },
        "textures": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "\"user:<name>\" data URLs, keyed by <name> (plan §2.11)."
        },
        "layers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Layer"
          }
        }
      },
      "required": [
        "schemaVersion",
        "meta",
        "duration",
        "looping",
        "seed",
        "layers"
      ]
    },
    "ParticleMeta": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "createdWith": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "createdWith",
        "notes"
      ]
    },
    "Layer": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "blend": {
          "$ref": "#/definitions/BlendMode"
        },
        "texture": {
          "$ref": "#/definitions/TextureRef"
        },
        "emission": {
          "$ref": "#/definitions/Emission"
        },
        "shape": {
          "$ref": "#/definitions/Shape"
        },
        "space": {
          "$ref": "#/definitions/SimSpace",
          "description": "Simulation space (schemaVersion 2). Default \"local\" = v1 behavior."
        },
        "inheritVelocity": {
          "type": "number",
          "description": "Fraction of the emitter's velocity added to each particle's spawn velocity (schemaVersion 2). Range [-2, 2]. Applied in world space only; ignored (but preserved) for local layers. Plain constant, not a ScalarInit, so it costs zero PRNG draws and preserves the normative 13-draw spawn order (§2.7)."
        },
        "attractorInfluence": {
          "type": "number",
          "description": "Per-layer scale on the host attractor's force (schemaVersion 4). Range [-2, 2]; 0 = the host `setAttractor` hook has no effect on this layer (the migration default, so every existing document is unaffected). A plain constant, not a ScalarTrack, so it costs zero PRNG draws (same rationale as `inheritVelocity`)."
        },
        "initial": {
          "$ref": "#/definitions/InitialProps"
        },
        "overLifetime": {
          "$ref": "#/definitions/OverLifetime"
        },
        "noise": {
          "anyOf": [
            {
              "$ref": "#/definitions/NoiseConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "Turbulence field (schemaVersion 3); null = off."
        },
        "bySpeed": {
          "anyOf": [
            {
              "$ref": "#/definitions/BySpeedConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "Speed-driven size/color/rotation remaps (schemaVersion 3); null = off."
        },
        "startColor": {
          "anyOf": [
            {
              "$ref": "#/definitions/StartColor"
            },
            {
              "type": "null"
            }
          ],
          "description": "Per-particle spawn-color variety (schemaVersion 3); null = off."
        },
        "randomFlip": {
          "anyOf": [
            {
              "$ref": "#/definitions/RandomFlip"
            },
            {
              "type": "null"
            }
          ],
          "description": "Per-particle random flip (schemaVersion 3); null = off."
        },
        "render": {
          "anyOf": [
            {
              "$ref": "#/definitions/RenderConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "Velocity-aligned / stretched rendering (schemaVersion 3); null = off."
        },
        "dissolve": {
          "anyOf": [
            {
              "$ref": "#/definitions/DissolveConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "Alpha-erosion dissolve (schemaVersion 4); null = off."
        },
        "collision": {
          "anyOf": [
            {
              "$ref": "#/definitions/CollisionConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "Simple collision (schemaVersion 3); null = off."
        },
        "attractor": {
          "anyOf": [
            {
              "$ref": "#/definitions/AttractorConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "Point attractor / vortex (schemaVersion 4); null = off."
        },
        "subEmitters": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/definitions/SubEmitterRef"
              }
            },
            {
              "type": "null"
            }
          ],
          "description": "Sub-emitters (schemaVersion 3); null = none (was reserved in v1/v2)."
        },
        "trail": {
          "anyOf": [
            {
              "$ref": "#/definitions/TrailConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "Per-particle trail (schemaVersion 3); null = off (was reserved in v1/v2)."
        }
      },
      "required": [
        "id",
        "name",
        "enabled",
        "blend",
        "texture",
        "emission",
        "shape",
        "space",
        "inheritVelocity",
        "attractorInfluence",
        "initial",
        "overLifetime",
        "noise",
        "bySpeed",
        "startColor",
        "randomFlip",
        "render",
        "dissolve",
        "collision",
        "attractor",
        "subEmitters",
        "trail"
      ]
    },
    "BlendMode": {
      "type": "string",
      "enum": [
        "normal",
        "add",
        "multiply",
        "screen"
      ]
    },
    "TextureRef": {
      "type": "object",
      "properties": {
        "ref": {
          "type": "string"
        },
        "frames": {
          "anyOf": [
            {
              "$ref": "#/definitions/Flipbook"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "ref",
        "frames"
      ]
    },
    "Flipbook": {
      "type": "object",
      "properties": {
        "cols": {
          "type": "number"
        },
        "rows": {
          "type": "number"
        },
        "fps": {
          "type": "number"
        },
        "mode": {
          "type": "string",
          "enum": [
            "loop",
            "once",
            "random"
          ]
        }
      },
      "required": [
        "cols",
        "rows",
        "fps",
        "mode"
      ]
    },
    "Emission": {
      "type": "object",
      "properties": {
        "rateOverTime": {
          "$ref": "#/definitions/ScalarTrack"
        },
        "rateOverDistance": {
          "anyOf": [
            {
              "$ref": "#/definitions/ScalarTrack"
            },
            {
              "type": "null"
            }
          ],
          "description": "Particles per pixel the emitter travels (schemaVersion 2). World-space only — keeps trail density uniform regardless of emitter speed. Null = disabled (v1 behavior). Same rate ceiling as rateOverTime."
        },
        "bursts": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Burst"
          }
        },
        "delay": {
          "type": "number"
        },
        "prewarm": {
          "type": "boolean"
        },
        "maxParticles": {
          "type": "number"
        }
      },
      "required": [
        "rateOverTime",
        "rateOverDistance",
        "bursts",
        "delay",
        "prewarm",
        "maxParticles"
      ]
    },
    "ScalarTrack": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "const": "constant"
            },
            "value": {
              "type": "number"
            }
          },
          "required": [
            "mode",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "const": "range"
            },
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            }
          },
          "required": [
            "mode",
            "min",
            "max"
          ]
        },
        {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "const": "curve"
            },
            "keys": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/CurveKey"
              }
            }
          },
          "required": [
            "mode",
            "keys"
          ]
        }
      ]
    },
    "CurveKey": {
      "type": "object",
      "properties": {
        "t": {
          "type": "number"
        },
        "v": {
          "type": "number"
        },
        "ease": {
          "$ref": "#/definitions/Ease"
        }
      },
      "required": [
        "t",
        "v"
      ]
    },
    "Ease": {
      "type": "string",
      "enum": [
        "linear",
        "easeIn",
        "easeOut",
        "easeInOut",
        "step"
      ]
    },
    "Burst": {
      "type": "object",
      "properties": {
        "time": {
          "type": "number"
        },
        "count": {
          "type": "number"
        },
        "spread": {
          "type": "number"
        },
        "cycles": {
          "type": "number",
          "description": "schemaVersion 3. Number of times the burst repeats; 1 = single (v2)."
        },
        "interval": {
          "type": "number",
          "description": "schemaVersion 3. Seconds between cycles (only meaningful when cycles > 1)."
        },
        "probability": {
          "type": "number",
          "description": "schemaVersion 3. Per-cycle firing probability in [0,1]; 1 = always (v2)."
        }
      },
      "required": [
        "time",
        "count",
        "spread",
        "cycles",
        "interval",
        "probability"
      ]
    },
    "Shape": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "point"
            },
            "emitFrom": {
              "$ref": "#/definitions/EmitFrom"
            }
          },
          "required": [
            "kind",
            "emitFrom"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "circle"
            },
            "radius": {
              "type": "number"
            },
            "innerRadius": {
              "type": "number",
              "description": "schemaVersion 3. Inner hole radius for a donut; 0 = full disc (v2)."
            },
            "arc": {
              "type": "number",
              "description": "schemaVersion 3. Angular span in degrees from 0° (+x, clockwise); 360 = full (v2)."
            },
            "arcMode": {
              "$ref": "#/definitions/ArcMode",
              "description": "schemaVersion 3. How the emission angle sweeps the arc."
            },
            "arcSpeed": {
              "type": "number",
              "description": "schemaVersion 3. Sweeps per second for loop/pingPong modes."
            },
            "emitFrom": {
              "$ref": "#/definitions/EmitFrom"
            }
          },
          "required": [
            "kind",
            "radius",
            "innerRadius",
            "arc",
            "arcMode",
            "arcSpeed",
            "emitFrom"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "cone"
            },
            "direction": {
              "type": "number"
            },
            "spread": {
              "type": "number"
            },
            "radius": {
              "type": "number"
            },
            "arcMode": {
              "$ref": "#/definitions/ArcMode",
              "description": "schemaVersion 3. How the emission angle sweeps the spread."
            },
            "arcSpeed": {
              "type": "number",
              "description": "schemaVersion 3. Sweeps per second for loop/pingPong modes."
            },
            "emitFrom": {
              "$ref": "#/definitions/EmitFrom"
            }
          },
          "required": [
            "kind",
            "direction",
            "spread",
            "radius",
            "arcMode",
            "arcSpeed",
            "emitFrom"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "rect"
            },
            "width": {
              "type": "number"
            },
            "height": {
              "type": "number"
            },
            "emitFrom": {
              "$ref": "#/definitions/EmitFrom"
            }
          },
          "required": [
            "kind",
            "width",
            "height",
            "emitFrom"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "edge"
            },
            "length": {
              "type": "number"
            },
            "emitFrom": {
              "$ref": "#/definitions/EmitFrom"
            }
          },
          "required": [
            "kind",
            "length",
            "emitFrom"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "texture"
            },
            "width": {
              "type": "number",
              "description": "schemaVersion 4. Rendered size in px of the mask, centered on the layer origin (mask cell (0,0) maps to the top-left corner). Must be > 0."
            },
            "height": {
              "type": "number"
            },
            "threshold": {
              "type": "number",
              "description": "schemaVersion 4. Alpha gate in [0,1]; a mask pixel emits only when its alpha (0..1) is >= threshold, and then weights spawn density by alpha."
            },
            "mask": {
              "$ref": "#/definitions/MaskData",
              "description": "schemaVersion 4. The base64-packed alpha mask sampled for positions."
            },
            "emitFrom": {
              "$ref": "#/definitions/EmitFrom"
            }
          },
          "required": [
            "kind",
            "width",
            "height",
            "threshold",
            "mask",
            "emitFrom"
          ]
        }
      ]
    },
    "EmitFrom": {
      "type": "string",
      "enum": [
        "volume",
        "surface"
      ]
    },
    "ArcMode": {
      "type": "string",
      "enum": [
        "random",
        "loop",
        "pingPong",
        "burstSpread"
      ],
      "description": "How the emission angle sweeps across a circle arc / cone spread (schemaVersion 3). `random` = the v2 behavior (uniform within the span). The others make emission march deterministically around the arc."
    },
    "MaskData": {
      "type": "object",
      "properties": {
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "data": {
          "type": "string"
        }
      },
      "required": [
        "width",
        "height",
        "data"
      ],
      "description": "A base64-packed alpha mask for emit-from-texture (schemaVersion 4). `data` is the base64 of `width·height` raw alpha bytes (0–255), row-major, top-left origin. Dims are integers in [1, 128]. The stored string is never re-encoded so round-trip is byte-stable; the 1×1 opaque default (`data: \"/w==\"`) sampled over `shape.width × shape.height` is exactly a uniform rect."
    },
    "SimSpace": {
      "type": "string",
      "enum": [
        "local",
        "world"
      ],
      "description": "The frame a layer's particles simulate in (schemaVersion 2). `local`: positions are relative to the effect origin and the renderer places the whole layer at the emitter (v1 behavior). `world`: particles spawn at the emitter's current position and thereafter simulate independently in the parent frame, so a moving emitter leaves them behind — the trail. (EMITTER_MOTION_PLAN)"
    },
    "InitialProps": {
      "type": "object",
      "properties": {
        "life": {
          "$ref": "#/definitions/ScalarInit"
        },
        "speed": {
          "$ref": "#/definitions/ScalarInit"
        },
        "size": {
          "$ref": "#/definitions/ScalarInit"
        },
        "rotation": {
          "$ref": "#/definitions/ScalarInit"
        },
        "angularVelocity": {
          "$ref": "#/definitions/ScalarInit"
        }
      },
      "required": [
        "life",
        "speed",
        "size",
        "rotation",
        "angularVelocity"
      ]
    },
    "ScalarInit": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "const": "constant"
            },
            "value": {
              "type": "number"
            }
          },
          "required": [
            "mode",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "const": "range"
            },
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            }
          },
          "required": [
            "mode",
            "min",
            "max"
          ]
        }
      ]
    },
    "OverLifetime": {
      "type": "object",
      "properties": {
        "size": {
          "anyOf": [
            {
              "$ref": "#/definitions/ScalarTrack"
            },
            {
              "type": "null"
            }
          ]
        },
        "color": {
          "$ref": "#/definitions/GradientTrack"
        },
        "rotation": {
          "anyOf": [
            {
              "$ref": "#/definitions/ScalarTrack"
            },
            {
              "type": "null"
            }
          ]
        },
        "velocity": {
          "$ref": "#/definitions/Velocity"
        }
      },
      "required": [
        "size",
        "color",
        "rotation",
        "velocity"
      ]
    },
    "GradientTrack": {
      "type": "object",
      "properties": {
        "keys": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GradientKey"
          }
        }
      },
      "required": [
        "keys"
      ]
    },
    "GradientKey": {
      "type": "object",
      "properties": {
        "t": {
          "type": "number"
        },
        "r": {
          "type": "number"
        },
        "g": {
          "type": "number"
        },
        "b": {
          "type": "number"
        },
        "a": {
          "type": "number"
        }
      },
      "required": [
        "t",
        "r",
        "g",
        "b",
        "a"
      ]
    },
    "Velocity": {
      "type": "object",
      "properties": {
        "gravity": {
          "$ref": "#/definitions/Vec2"
        },
        "drag": {
          "anyOf": [
            {
              "$ref": "#/definitions/ScalarTrack"
            },
            {
              "type": "null"
            }
          ]
        },
        "speedMultiplier": {
          "anyOf": [
            {
              "$ref": "#/definitions/ScalarTrack"
            },
            {
              "type": "null"
            }
          ]
        },
        "x": {
          "anyOf": [
            {
              "$ref": "#/definitions/ScalarTrack"
            },
            {
              "type": "null"
            }
          ],
          "description": "Velocity over lifetime (schemaVersion 3), all additive px/s at ageNorm (added into the position update, not accumulated into stored velX/velY). `x`/`y` are directional; `orbital` is deg/s clockwise about the layer origin; `radial` is px/s outward. Null = the field contributes nothing."
        },
        "y": {
          "anyOf": [
            {
              "$ref": "#/definitions/ScalarTrack"
            },
            {
              "type": "null"
            }
          ]
        },
        "orbital": {
          "anyOf": [
            {
              "$ref": "#/definitions/ScalarTrack"
            },
            {
              "type": "null"
            }
          ]
        },
        "radial": {
          "anyOf": [
            {
              "$ref": "#/definitions/ScalarTrack"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "gravity",
        "drag",
        "speedMultiplier",
        "x",
        "y",
        "orbital",
        "radial"
      ]
    },
    "Vec2": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y"
      ]
    },
    "NoiseConfig": {
      "type": "object",
      "properties": {
        "strength": {
          "$ref": "#/definitions/ScalarTrack"
        },
        "frequency": {
          "type": "number"
        },
        "scrollSpeed": {
          "type": "number"
        },
        "octaves": {
          "type": "number"
        }
      },
      "required": [
        "strength",
        "frequency",
        "scrollSpeed",
        "octaves"
      ],
      "description": "Turbulence / curl-noise field applied as a bounded position perturbation (schemaVersion 3). `strength` is px/s over the particle's life; `frequency` scales the spatial lattice; `scrollSpeed` scrolls the field over time; `octaves` (1..3) stacks detail."
    },
    "BySpeedConfig": {
      "type": "object",
      "properties": {
        "range": {
          "type": "object",
          "properties": {
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            }
          },
          "required": [
            "min",
            "max"
          ]
        },
        "size": {
          "anyOf": [
            {
              "$ref": "#/definitions/ScalarTrack"
            },
            {
              "type": "null"
            }
          ]
        },
        "color": {
          "anyOf": [
            {
              "$ref": "#/definitions/GradientTrack"
            },
            {
              "type": "null"
            }
          ]
        },
        "rotation": {
          "anyOf": [
            {
              "$ref": "#/definitions/ScalarTrack"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "range",
        "size",
        "color",
        "rotation"
      ],
      "description": "Remap size/color/rotation by a particle's instantaneous speed (schemaVersion 3). Speed is normalized across [range.min, range.max]; each non-null channel is then applied at that t. Curve/constant tracks only — no per-particle range mode (no reserved PRNG draw)."
    },
    "StartColor": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "const": "gradients"
            },
            "a": {
              "$ref": "#/definitions/GradientTrack"
            },
            "b": {
              "$ref": "#/definitions/GradientTrack"
            }
          },
          "required": [
            "mode",
            "a",
            "b"
          ]
        },
        {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "const": "palette"
            },
            "colors": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/RGBAColor"
              }
            }
          },
          "required": [
            "mode",
            "colors"
          ]
        }
      ],
      "description": "Per-particle spawn-color variety (schemaVersion 3), applied as a constant tint multiplier over the over-lifetime gradient (L7 amendment). `gradients`: lerp between two gradients by a per-particle uniform. `palette`: pick one of 1..16 fixed colors per particle."
    },
    "RGBAColor": {
      "type": "object",
      "properties": {
        "r": {
          "type": "number"
        },
        "g": {
          "type": "number"
        },
        "b": {
          "type": "number"
        },
        "a": {
          "type": "number"
        }
      },
      "required": [
        "r",
        "g",
        "b",
        "a"
      ],
      "description": "RGBA color, each channel in [0,1] (schemaVersion 3)."
    },
    "RandomFlip": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y"
      ],
      "description": "Per-particle random mirroring (schemaVersion 3). `x`/`y` are the probabilities in [0,1] of flipping that axis (negative sprite scale)."
    },
    "RenderConfig": {
      "type": "object",
      "properties": {
        "align": {
          "type": "string",
          "enum": [
            "none",
            "velocity"
          ]
        },
        "speedScale": {
          "type": "number"
        },
        "minStretch": {
          "type": "number"
        },
        "maxStretch": {
          "type": "number"
        }
      },
      "required": [
        "align",
        "speedScale",
        "minStretch",
        "maxStretch"
      ],
      "description": "Velocity-aligned rendering + speed stretch (schemaVersion 3). `align: \"velocity\"` rotates the sprite to face its motion; `speedScale` grows the along-motion stretch with speed, clamped to [minStretch, maxStretch]."
    },
    "DissolveConfig": {
      "type": "object",
      "properties": {
        "frequency": {
          "type": "number"
        },
        "scroll": {
          "$ref": "#/definitions/Vec2"
        },
        "edgeWidth": {
          "type": "number"
        },
        "edgeColor": {
          "anyOf": [
            {
              "$ref": "#/definitions/RGBAColor"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "frequency",
        "scroll",
        "edgeWidth",
        "edgeColor"
      ],
      "description": "Alpha-erosion \"dissolve\" (schemaVersion 4); renderer-only, off when null. A per-layer noise pattern erodes the particle's alpha: the final render alpha is the dissolve progress. `frequency` is the pattern repeat across the sprite in (0, 64]; `scroll` is UV/s over the effect clock; `edgeWidth` in [0,1] is the soft erosion band; `edgeColor` (null = off) tints a hot edge along that band."
    },
    "CollisionConfig": {
      "type": "object",
      "properties": {
        "shape": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "floor"
                },
                "y": {
                  "type": "number"
                }
              },
              "required": [
                "kind",
                "y"
              ]
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "rect"
                },
                "x": {
                  "type": "number"
                },
                "y": {
                  "type": "number"
                },
                "width": {
                  "type": "number"
                },
                "height": {
                  "type": "number"
                }
              },
              "required": [
                "kind",
                "x",
                "y",
                "width",
                "height"
              ]
            }
          ]
        },
        "bounce": {
          "type": "number"
        },
        "dampen": {
          "type": "number"
        },
        "lifetimeLoss": {
          "type": "number"
        }
      },
      "required": [
        "shape",
        "bounce",
        "dampen",
        "lifetimeLoss"
      ],
      "description": "Simple collision plane(s) in the layer's sim frame (schemaVersion 3). `floor`: a horizontal line at `y`. `rect`: keep particles inside the box. `bounce`/`dampen`/`lifetimeLoss` are all in [0,1]."
    },
    "AttractorConfig": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "strength": {
          "$ref": "#/definitions/ScalarTrack"
        },
        "tangential": {
          "anyOf": [
            {
              "$ref": "#/definitions/ScalarTrack"
            },
            {
              "type": "null"
            }
          ]
        },
        "radius": {
          "type": "number"
        },
        "falloff": {
          "$ref": "#/definitions/AttractorFalloff"
        },
        "killRadius": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "strength",
        "tangential",
        "radius",
        "falloff",
        "killRadius"
      ],
      "description": "Point attractor / vortex in the layer's sim frame (schemaVersion 4). Applies a radial (`strength`) and tangential (`tangential`, orbiting) acceleration in px/s² over the particle's ageNorm to particles within `radius`; both tracks are constant/curve only (no per-particle range mode, so zero PRNG draws — the same ruling as `noise.strength`). `killRadius` (0 = off) kills particles that fall inside it via the M7 ageLoss mechanism, so death-trigger sub-emitters fire. See FORMAT_SPEC \"Point attractor / vortex\" for the force + sign rules."
    },
    "AttractorFalloff": {
      "type": "string",
      "enum": [
        "none",
        "linear",
        "smooth"
      ],
      "description": "How an attractor's force falls off toward its `radius` (schemaVersion 4). `none` = full strength inside the radius (hard cutoff); `linear` = ramps to 0 at the edge; `smooth` = smoothstep ease."
    },
    "SubEmitterRef": {
      "type": "object",
      "properties": {
        "trigger": {
          "$ref": "#/definitions/SubTrigger"
        },
        "layerId": {
          "type": "string"
        },
        "count": {
          "type": "number"
        },
        "probability": {
          "type": "number"
        },
        "inheritVelocity": {
          "type": "number"
        }
      },
      "required": [
        "trigger",
        "layerId",
        "count",
        "probability",
        "inheritVelocity"
      ],
      "description": "How a layer's particles spawn children on another layer (schemaVersion 3). `layerId` names a sibling layer (depth 1: that layer must have `subEmitters: null`). `count` children per event, gated by `probability`."
    },
    "SubTrigger": {
      "type": "string",
      "enum": [
        "birth",
        "death",
        "collision"
      ],
      "description": "The event that fires a sub-emitter (schemaVersion 3)."
    },
    "TrailConfig": {
      "type": "object",
      "properties": {
        "maxPoints": {
          "type": "number"
        },
        "minVertexDistance": {
          "type": "number"
        },
        "width": {
          "$ref": "#/definitions/ScalarTrack"
        },
        "color": {
          "anyOf": [
            {
              "$ref": "#/definitions/GradientTrack"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "maxPoints",
        "minVertexDistance",
        "width",
        "color"
      ],
      "description": "Per-particle ribbon trail (schemaVersion 3). Polyline of the last `maxPoints` positions; `width` over trail t (0 = head); `color` over trail length (null = the particle's current color)."
    }
  }
}
